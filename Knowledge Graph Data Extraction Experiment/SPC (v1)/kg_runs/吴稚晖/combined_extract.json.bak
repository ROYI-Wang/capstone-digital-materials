      "source_author": "吴稚晖",
      "source_file": "E:\\1研究生\\岭南大学\\论文毕业\\capstone\\资料\\新的内容开始了\\local_upload\\input_w0\\吴稚晖.txt"
    },
    {
      "id": "吴稚晖_001_b4c0e810_s0047:c5",
      "speaker": "",
      "claim": "衣食住都要化劳力的高价，方能备物。",
      "target": "衣食住与劳力",
      "claim_type": "社会理论主张",
      "claim_status": "作者直接主张",
      "polarity": "neutral",
      "evidence": "侥幸止有衣食住，都要化劳力的高价，方能备物。",
