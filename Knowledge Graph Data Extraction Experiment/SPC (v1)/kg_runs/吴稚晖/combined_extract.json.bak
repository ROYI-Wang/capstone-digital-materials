    {
      "id": "吴稚晖_001_b4c0e810_s0031:e2",
      "name": "动物",
      "canonical_name": "动物",
      "type": "概念",
      "evidence": "人便是外面止剩两只脚，却得到了两只手，内面有三斤二两脑髓，五千零四十八根脑筋，比较占有多额神经系质的动物",
      "confidence": 1.0,
      "segment_id": "吴稚晖_001_b4c0e810_s0031",
