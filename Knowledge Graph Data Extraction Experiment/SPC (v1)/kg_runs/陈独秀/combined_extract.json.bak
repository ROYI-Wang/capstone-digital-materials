    },
    {
      "id": "陈独秀_002_69a217f6_s0000:c4",
      "speaker": "陈独秀",
      "claim": "社会上有相类的因之现象，必将有相类的果之现象；惟其果之现象之特定的时空及现象中之个体现象，则另有其因果关系，而非社会科学范围以内之事，这本是社会科学重要方法之一。",
      "target": "社会科学",
      "claim_type": "方法论主张",
      "claim_status": "作者直接主张",
      "polarity": "positive",
      "evidence": "社会上有相类的因之现象，必将有相类的果之现象；惟其果之现象之特定的时空及现象中之个体现象，则另有其因果关系，而非社会科学范围以内之事，这本是社会科学重要方法之一。",
      "confidence": 1.0,
