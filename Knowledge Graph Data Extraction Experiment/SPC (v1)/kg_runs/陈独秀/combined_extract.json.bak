    },
    {
      "id": "陈独秀_002_69a217f6_s0010:c6",
      "speaker": "张君劢",
      "claim": "科学有一定之公例，人生观则可以人类意志左右其间，而日在创造之中。",
      "target": "人生观",
      "claim_type": "定义性主张",
      "claim_status": "直接引用",
      "polarity": "positive",
      "evidence": "张先生说：“所以以人生观与科学对举者，谓科学有一定之公例者也，人生观则可以人类意志左右其间，而日在创造之中者也。”",
      "confidence": 1.0,
      "segment_id": "陈独秀_002_69a217f6_s0010",
      "local_id": "c6",
      "article_id": "陈独秀_002_69a217f6",
