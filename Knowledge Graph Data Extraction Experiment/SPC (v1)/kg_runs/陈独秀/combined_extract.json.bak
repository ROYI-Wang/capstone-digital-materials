      "claim_type": "定义性主张",
      "claim_status": "作者直接主张",
      "polarity": "positive",
      "evidence": "则人生观之特点所在，曰主观的，曰直觉的，曰综合的，曰自由意志的，曰单一性的",
      "confidence": 1.0,
      "segment_id": "陈独秀_001_d263aca8_s0012",
      "local_id": "c3",
      "article_id": "陈独秀_001_d263aca8",
      "article_title": "答适之",
