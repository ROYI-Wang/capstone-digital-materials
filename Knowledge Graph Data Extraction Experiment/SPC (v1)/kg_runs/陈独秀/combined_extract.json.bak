    },
    {
      "id": "陈独秀_001_d263aca8_s0011:r4",
      "head": "智慧测验",
      "head_type": "概念",
      "relation": "作为论据支持",
      "tail": "智愚之别，由此可见也",
      "tail_type": "观点",
      "polarity": "positive",
      "evidence": "智慧测验者，就学童之智识，而测定其高下之标准也。高者则速其卒业之期，下者则设法以促进之，智愚之别，由此可见也。",
      "confidence": 1.0,
      "segment_id": "陈独秀_001_d263aca8_s0011",
      "local_id": "r4",
      "article_id": "陈独秀_001_d263aca8",
      "article_title": "答适之",
      "source_author": "陈独秀",
      "source_file": "E:\\1研究生\\岭南大学\\论文毕业\\capstone\\资料\\新的内容开始了\\local_upload\\input_w2\\陈独秀.txt"
    },
    {
      "id": "陈独秀_001_d263aca8_s0011:r5",
      "head": "犯罪统计",
      "head_type": "概念",
      "relation": "作为论据支持",
      "tail": "国民道德之高下，可窥见也",
      "tail_type": "观点",
      "polarity": "positive",
      "evidence": "犯罪统计之中所发见之现象，曰冬季则盗贼多，以失业者众也；春夏秋则盗贼少，以农事忙而失业者少也。如是，则国民道德之高下，可窥见也。",
      "confidence": 1.0,
      "segment_id": "陈独秀_001_d263aca8_s0011",
      "local_id": "r5",
      "article_id": "陈独秀_001_d263aca8",
      "article_title": "答适之",
      "source_author": "陈独秀",
      "source_file": "E:\\1研究生\\岭南大学\\论文毕业\\capstone\\资料\\新的内容开始了\\local_upload\\input_w2\\陈独秀.txt"
    },
    {
      "id": "陈独秀_001_d263aca8_s0011:r6",
      "head": "方今国中竟言新文化，而文化转移之枢纽，不外乎人生观。吾有吾之文化，西洋有西洋之文化。西洋之有益者如何采之，有害者如何革除之；凡此取舍之间，皆决之于观点。观点定，而后精神上之思潮、物质上之制度，乃可",
      "head_type": "人物",
      "relation": "批评",
      "tail": "精神分析或智慧测验者",
      "tail_type": "阵营/群体",
      "polarity": "negative",
      "evidence": "虽主张精神分析或智慧测验者，恐亦无法以解释其由来矣。",
      "confidence": 1.0,
      "segment_id": "陈独秀_001_d263aca8_s0011",
