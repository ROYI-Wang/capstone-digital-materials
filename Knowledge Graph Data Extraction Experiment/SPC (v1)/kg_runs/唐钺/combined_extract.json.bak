    },
    {
      "id": "唐钺_000_b5cd146b_s0004:cit2",
      "citer": "唐钺",
      "quoted_author": "杜里舒",
      "quoted_work": "《讲演录》《近世心理问题》",
      "quoted_claim": "体验者乃断断续续的，而非永续的。故当比之于电光之烁闪，不得名曰河流。‘我有’、‘我体验’既为点的，则此断续势不能熔成一片，如不尽之江河。",
      "function": "援引权威支持",
      "evidence": "杜里舒说：“以我观之，体验者乃断断续续的，而非永续的。故当比之于电光之烁闪，不得名曰河流。‘我有’、‘我体验’既为点的，则此断续势不能熔成一片，如不尽之江河。”（杜里舒《讲演录》《近世心理问题》第四期第二十一页）",
      "confidence": 1.0,
      "segment_id": "唐钺_000_b5cd146b_s0004",
