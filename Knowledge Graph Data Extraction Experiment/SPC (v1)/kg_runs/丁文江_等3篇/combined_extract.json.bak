      "source_file": "E:\\1研究生\\岭南大学\\论文毕业\\capstone\\资料\\新的内容开始了\\local_upload\\input_w0\\丁文江3.txt"
    },
    {
      "speaker": "作者",
      "content": "科学以心理上的现象为内容，对概念、推论有严格审查",
      "type": "主张",
      "evidence": "原文第一段",
      "segment_id": "丁文江_000_3ba07a5e_s0013",
      "article_id": "丁文江_000_3ba07a5e"
    },
    {
      "speaker": "作者",
      "content": "审查方法基于两条原则：常人心理内容性质相同，心理联想能力取决于环境与遗传",
      "type": "主张",
      "evidence": "原文第二段",
      "segment_id": "丁文江_000_3ba07a5e_s0013",
      "article_id": "丁文江_000_3ba07a5e"
    },
    {
      "speaker": "作者",
      "content": "常人思想的工具是同常人的一类的机器",
      "type": "主张",
      "evidence": "原文第二段",
      "segment_id": "丁文江_000_3ba07a5e_s0013",
      "article_id": "丁文江_000_3ba07a5e"
    },
    {
      "speaker": "作者",
      "content": "人人可以拿他的不讲理的人生观来起而主张之",
      "type": "观点",
      "claim_type": "批判性主张",
      "evidence": "原文：人人可以拿他的不讲理的人生观来起而主张之",
      "segment_id": "丁文江_000_3ba07a5e_s0026",
      "article_id": "丁文江_000_3ba07a5e"
    },
    {
      "speaker": "作者",
      "content": "是非真伪是无标准的",
      "type": "观点",
      "claim_type": "批判性主张",
      "evidence": "原文：何况是非真伪是无标准的呢",
      "segment_id": "丁文江_000_3ba07a5e_s0026",
      "article_id": "丁文江_000_3ba07a5e"
    },
    {
      "speaker": "作者",
      "content": "一个人的人生观不妨矛盾",
      "type": "观点",
      "claim_type": "批判性主张",
      "evidence": "原文：一个人的人生观当然不妨矛盾",
      "segment_id": "丁文江_000_3ba07a5e_s0026",
      "article_id": "丁文江_000_3ba07a5e"
    },
    {
      "speaker": "作者",
      "content": "这种社会可以一日居吗",
      "type": "观点",
      "claim_type": "反问性主张",
      "evidence": "原文：这种社会可以一日居吗",
      "segment_id": "丁文江_000_3ba07a5e_s0026",
      "article_id": "丁文江_000_3ba07a5e"
    },
    {
      "speaker": "作者",
      "content": "对于科学的误解：以为科学是物质的，机械的",
      "type": "观点",
      "claim_type": "解释性主张",
      "evidence": "原文：以为科学是物质的，机械的",
      "segment_id": "丁文江_000_3ba07a5e_s0026",
      "article_id": "丁文江_000_3ba07a5e"
    },
    {
      "speaker": "作者",
      "content": "玄学家、教育家、政治家把物质文明的罪名加到科学身上",
      "type": "观点",
      "claim_type": "批判性主张",
      "evidence": "原文第一句",
      "segment_id": "丁文江_000_3ba07a5e_s0039",
      "article_id": "丁文江_000_3ba07a5e"
    },
    {
      "speaker": "作者",
      "content": "许多中国人不知道科学方法和经学大师治学方法一样",
      "type": "观点",
      "claim_type": "事实性主张",
      "evidence": "原文第二段",
      "segment_id": "丁文江_000_3ba07a5e_s0039",
      "article_id": "丁文江_000_3ba07a5e"
    },
    {
      "speaker": "作者",
      "content": "他们误以为西洋科学是机械的、物质的、向外的、形而下的",
      "type": "观点",
      "claim_type": "描述性主张",
      "evidence": "原文第二段",
      "segment_id": "丁文江_000_3ba07a5e_s0039",
      "article_id": "丁文江_000_3ba07a5e"
    },
    {
      "speaker": "作者",
      "content": "庚子以后要以科学为用，不敢公然诽谤科学",
      "type": "观点",
      "claim_type": "历史性主张",
      "evidence": "原文第二段",
      "segment_id": "丁文江_000_3ba07a5e_s0039",
      "article_id": "丁文江_000_3ba07a5e"
    },
    {
      "speaker": "作者",
      "content": "欧战发生，产生科学的欧洲要破产了",
      "type": "观点",
      "claim_type": "历史性主张",
      "evidence": "原文第二段",
      "segment_id": "丁文江_000_3ba07a5e_s0039",
      "article_id": "丁文江_000_3ba07a5e"
    },
    {
      "speaker": "作者",
      "content": "他们抬出我们的精神文明来补救物质文明",
      "type": "观点",
      "claim_type": "描述性主张",
      "evidence": "原文第二段",
      "segment_id": "丁文江_000_3ba07a5e_s0039",
      "article_id": "丁文江_000_3ba07a5e"
    },
    {
      "speaker": "张君劢",
      "content": "自孔孟以至宋元明之理学家侧重内心生活之修养，其结果为精神文明",
      "type": "观点",
      "claim_type": "定义性主张",
      "evidence": "原文引用",
      "segment_id": "丁文江_000_3ba07a5e_s0039",
      "article_id": "丁文江_000_3ba07a5e"
    },
    {
      "speaker": "作者",
      "content": "提倡内功的理学家，宋朝不止一个，最明显的是陆象山一派",
      "type": "观点",
      "claim_type": "事实性主张",
      "evidence": "原文第三段",
      "segment_id": "丁文江_000_3ba07a5e_s0039",
      "article_id": "丁文江_000_3ba07a5e"
    },
    {
      "speaker": "作者",
      "content": "当时的学者还主张读书，还不是完全空疏",
      "type": "观点",
      "claim_type": "事实性主张",
      "evidence": "原文第三段",
      "segment_id": "丁文江_000_3ba07a5e_s0039",
      "article_id": "丁文江_000_3ba07a5e"
    },
    {
      "speaker": "作者",
      "content": "原子论是达尔登创造的，但原子包括分子在内",
      "type": "陈述",
      "segment_id": "丁文江2_000_e838922e_s0019",
      "article_id": "丁文江2_000_e838922e"
    },
    {
      "speaker": "作者",
      "content": "分子的观念起于阿我喀杜罗",
      "type": "陈述",
      "segment_id": "丁文江2_000_e838922e_s0019",
      "article_id": "丁文江2_000_e838922e"
    },
    {
      "speaker": "作者",
      "content": "铣质发明后，原子会自动分裂，原子论和原质观念需修正",
      "type": "论证",
      "segment_id": "丁文江2_000_e838922e_s0019",
      "article_id": "丁文江2_000_e838922e"
    },
    {
      "speaker": "作者",
      "content": "力同原子都是理化学根本概念，有变动",
      "type": "论证",
      "segment_id": "丁文江2_000_e838922e_s0019",
      "article_id": "丁文江2_000_e838922e"
    },
    {
      "speaker": "作者",
      "content": "君劢所谓一成不变的公例在物理学上找不到",
      "type": "反驳性主张",
      "segment_id": "丁文江2_000_e838922e_s0019",
      "article_id": "丁文江2_000_e838922e"
    },
    {
      "speaker": "作者",
      "content": "严正科学并非牢固不拔",
      "type": "反驳性主张",
      "segment_id": "丁文江2_000_e838922e_s0019",
      "article_id": "丁文江2_000_e838922e"
    },
    {
      "speaker": "赫胥黎",
      "content": "酬报和最重的惩罚都是跟这一桩举动走的",
      "type": "观点",
      "evidence": "文本开头引用",
      "segment_id": "丁文江2_000_e838922e_s0032",
      "article_id": "丁文江2_000_e838922e"
    },
    {
      "speaker": "赫胥黎",
      "content": "必须严格的不信任一切没有充分证据的东西",
      "type": "观点",
      "evidence": "文本引用赫胥黎的话",
      "segment_id": "丁文江2_000_e838922e_s0032",
      "article_id": "丁文江2_000_e838922e"
    },
    {
      "speaker": "赫胥黎",
      "content": "用比喻同猜想来同我说是没有用的",
      "type": "观点",
      "evidence": "文本引用赫胥黎的话",
      "segment_id": "丁文江2_000_e838922e_s0032",
      "article_id": "丁文江2_000_e838922e"
    },
    {
      "speaker": "笛卡儿",
      "content": "敬奉怀疑",
      "type": "观点",
      "evidence": "文本引用笛卡儿",
      "segment_id": "丁文江2_000_e838922e_s0032",
      "article_id": "丁文江2_000_e838922e"
    },
    {
      "speaker": "葛笛",
      "content": "这种怀疑的目的是要征服怀疑自己",
      "type": "观点",
      "evidence": "文本引用葛笛的话",
      "segment_id": "丁文江2_000_e838922e_s0032",
      "article_id": "丁文江2_000_e838922e"
    },
    {
      "speaker": "作者",
      "content": "存疑主义是积极的，不是消极的；是奋斗的，不是旁观的",
      "type": "观点",
      "evidence": "文本作者总结",
      "segment_id": "丁文江2_000_e838922e_s0032",
      "article_id": "丁文江2_000_e838922e"
    },
    {
      "speaker": "文本作者",
      "content": "科学不承认是真的",
      "type": "主张",
      "evidence": "得同样的推论，科学不承认是真的",
      "segment_id": "丁文江2_000_e838922e_s0045",
      "article_id": "丁文江2_000_e838922e"
    },
    {
      "speaker": "文本作者",
      "content": "能不能是一件事，肯不肯又是一件事",
      "type": "主张",
      "evidence": "因为能不能是一件事，肯不肯又是一件事",
      "segment_id": "丁文江2_000_e838922e_s0045",
      "article_id": "丁文江2_000_e838922e"
    },
    {
      "speaker": "巴尔福",
      "content": "人类有自由意向的学说科学根据薄弱但可爱，不肯放弃",
      "type": "主张",
      "evidence": "他说人类有自由意向的学说，科学上的根据很薄弱，他是知道的，但是他觉得这种学说很可爱，不肯放弃他",
      "segment_id": "丁文江2_000_e838922e_s0045",
      "article_id": "丁文江2_000_e838922e"
    },
    {
      "speaker": "文本作者",
      "content": "肯不肯是情感问题",
      "type": "主张",
      "evidence": "足见得他的肯不肯是情感问题",
      "segment_id": "丁文江2_000_e838922e_s0045",
      "article_id": "丁文江2_000_e838922e"
    },
    {
      "speaker": "文本作者",
      "content": "许多人重情感而轻知识",
      "type": "主张",
      "evidence": "许多人重情感而轻知识",
      "segment_id": "丁文江2_000_e838922e_s0045",
      "article_id": "丁文江2_000_e838922e"
    },
    {
      "speaker": "文本作者",
      "content": "非不能也，不肯也",
      "type": "主张",
      "evidence": "所以往往的“非不能也，不肯也”",
      "segment_id": "丁文江2_000_e838922e_s0045",
      "article_id": "丁文江2_000_e838922e"
    },
    {
      "speaker": "文本作者",
      "content": "我们现在是就知识论知识，没有把情感计算在内",
      "type": "主张",
      "evidence": "我们现在是就知识论知识，没有把情感计算在内",
      "segment_id": "丁文江2_000_e838922e_s0045",
      "article_id": "丁文江2_000_e838922e"
    },
    {
      "speaker": "文本作者",
      "content": "物质科学同精神科学没有根本的分别",
      "type": "主张",
      "evidence": "我们说物质科学同精神科学没有根本的分别",
      "segment_id": "丁文江2_000_e838922e_s0045",
      "article_id": "丁文江2_000_e838922e"
    },
    {
      "speaker": "文本作者",
      "content": "物质科学与精神科学研究的材料同为现象，方法同为归纳",
      "type": "主张",
      "evidence": "因为他们所研究的材料同为现象，研究的方法同为归纳",
      "segment_id": "丁文江2_000_e838922e_s0045",
      "article_id": "丁文江2_000_e838922e"
    },
    {
      "speaker": "文本作者",
      "content": "精神与物质有无分别是哲学大问题",
      "type": "主张",
      "evidence": "至于精神同物质根本有无分别，如果有分别，究竟是一种什么质，本来是哲学上大问题",
      "segment_id": "丁文江2_000_e838922e_s0045",
      "article_id": "丁文江2_000_e838922e"
    },
    {
      "speaker": "文本作者",
      "content": "君劢用内与外同我与非我说明精神物质等于没有说明",
      "type": "主张",
      "evidence": "君劢拿内与外同我与非我来说明精神物质，同没有说明一样",
      "segment_id": "丁文江2_000_e838922e_s0045",
      "article_id": "丁文江2_000_e838922e"
    },
    {
      "speaker": "文本作者",
      "content": "内与外同我与非我本身的界限定义极难解决",
      "type": "主张",
      "evidence": "因为内与外同我与非我本身的界限定义，也是极难解决的",
      "segment_id": "丁文江2_000_e838922e_s0045",
      "article_id": "丁文江2_000_e838922e"
    },
    {
      "speaker": "作者",
      "content": "不反对宗教，但不承认神学是宗教",
      "type": "观点",
      "claim_type": "主张",
      "evidence": "原文第一句",
