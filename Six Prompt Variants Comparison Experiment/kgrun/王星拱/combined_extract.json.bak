    },
    {
      "id": "王星拱_000_4d6fdc04_s0011:c1",
      "speaker": "王星拱",
      "claim": "人类有求生活与求较好的生活之欲望，这些欲望的满足与否产生愉快或悲苦的感情，其途径虽不简单但可理解，可以用方法去发生感情。",
      "target": "感情",
      "claim_type": "知识论主张",
      "claim_status": "作者直接主张",
      "polarity": "positive",
      "evidence": "人类有求生活（包含个体与种族而言）与求较好的生活（即所谓向上的生活）之欲望。能够满足这些欲望的，就发生愉快的感情，不能满足这些欲望的，就发生悲苦的感情。其经历的途径，虽不能像二加二得四那样容易明了，然而却也不像“哲子石”（Philosopher's Stone）那样底不可捉摸。若是我们明白了这个途径，却可以用方法去发生感情。",
      "confidence": 0.9,
      "segment_id": "王星拱_000_4d6fdc04_s0011",
      "local_id": "c1",
      "article_id": "王星拱_000_4d6fdc04",
      "article_title": "科学与人生观",
      "source_author": "王星拱",
      "source_file": "E:\\1研究生\\岭南大学\\论文毕业\\capstone\\资料\\新的内容开始了\\local_upload\\input_w3\\王星拱.txt"
    },
    {
