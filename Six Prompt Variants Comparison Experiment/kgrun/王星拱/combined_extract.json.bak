    },
    {
      "id": "王星拱_000_4d6fdc04_s0002:c2",
      "speaker": "王星拱",
      "claim": "科学所凭藉以构造起来的有两个原理：因果之原理和齐一之原理。",
      "target": "科学",
      "claim_type": "定义性主张",
      "claim_status": "作者直接主张",
      "polarity": "positive",
      "evidence": "科学所凭藉以构造起来的，有两个原理:(一）是因果之原理（Causality),(二）是齐一之原理（Uniformity）。",
      "confidence": 0.9,
      "segment_id": "王星拱_000_4d6fdc04_s0002",
      "local_id": "c2",
      "article_id": "王星拱_000_4d6fdc04",
