      "original_name": "必然的法则（自然的法则）"
    },
    {
      "id": "范寿康_000_14d2ac72_s0006:e4",
      "name": "当然的法则（规范）",
      "canonical_name": "当然的法则",
      "type": "概念",
      "evidence": "当然的法则（规范）却是不然，在放任的时候，我们未必服从，也未必不服从，换言之，当然的法则的实行非必然的，是可以随人而异的；但是在他一方面，当然的法则，纵使有时有人去背犯他，却是我们所要\n求的，所以我们对于他们，总想竭力发现，并想竭力尊奉。",
      "confidence": 1.0,
      "segment_id": "范寿康_000_14d2ac72_s0006",
      "local_id": "e4",
      "article_id": "范寿康_000_14d2ac72",
