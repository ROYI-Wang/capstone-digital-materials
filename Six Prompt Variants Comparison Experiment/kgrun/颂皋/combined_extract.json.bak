      "source_file": "E:\\1研究生\\岭南大学\\论文毕业\\capstone\\资料\\新的内容开始了\\local_upload\\input_w2\\颂皋.txt"
    },
    {
      "id": "颂皋_000_0fffa40d_s0004:c6",
      "speaker": "颂皋",
      "claim": "明乎此理，吾人可以自为玄学家，而将上述各问题，加以详密的讨论矣",
      "target": "玄学家",
      "claim_type": "方法论主张",
      "claim_status": "作者直接主张",
      "polarity": "positive",
      "evidence": "明乎此理，吾人可以自为玄学家，而将上述各问题，加以详密的讨论矣",
      "confidence": 0.9,
      "segment_id": "s0004",
      "local_id": "c6",
      "article_id": "颂皋_000_0fffa40d",
      "article_title": "玄学上之问题",
      "source_author": "颂皋",
      "source_file": "E:\\1研究生\\岭南大学\\论文毕业\\capstone\\资料\\新的内容开始了\\local_upload\\input_w2\\颂皋.txt"
    },
    {
      "speaker": "颂皋",
      "content": "丁文君与张君劢为科学与玄学之争，发表许多文章，引起学术界之注意",
      "type": "陈述",
      "evidence": "文本第一句",
      "segment_id": "颂皋_000_0fffa40d_s0000",
      "article_id": "颂皋_000_0fffa40d"
    },
    {
      "speaker": "颂皋",
      "content": "一时起而招辩者，类皆国内知名之士，对于专门之学，皆有深造",
      "type": "陈述",
      "evidence": "文本第二句",
      "segment_id": "颂皋_000_0fffa40d_s0000",
      "article_id": "颂皋_000_0fffa40d"
    },
    {
      "speaker": "颂皋",
      "content": "亦有主张偏激，思想之间，发生绝大缺陷者，考其所以致此之由，大率对于玄学之所以为玄学，不无稍欠了解",
      "type": "陈述",
      "evidence": "文本第三句",
      "segment_id": "颂皋_000_0fffa40d_s0000",
      "article_id": "颂皋_000_0fffa40d"
    },
    {
      "speaker": "颂皋",
      "content": "乾姆斯所著哲学问题中有专论'玄学上之问题'一章，颇能将玄学之界说与夫玄学的问题之性质阐明无遗",
      "type": "陈述",
      "evidence": "文本第四句",
      "segment_id": "颂皋_000_0fffa40d_s0000",
      "article_id": "颂皋_000_0fffa40d"
    },
    {
      "speaker": "颂皋",
      "content": "欲于玄学一词，加以明确之定义，诚为不可能之事",
      "type": "陈述",
      "evidence": "文本第五句",
      "segment_id": "颂皋_000_0fffa40d_s0000",
      "article_id": "颂皋_000_0fffa40d"
    },
    {
      "speaker": "颂皋",
      "content": "玄学乃所以讨论各种空虚的抽象的普遍的问题，而为科学与人生所未能解决者",
      "type": "定义",
      "evidence": "文本第六句",
      "segment_id": "颂皋_000_0fffa40d_s0000",
      "article_id": "颂皋_000_0fffa40d"
    },
    {
      "speaker": "颂皋",
      "content": "何谓思想？何谓事物？思想与事物之间如何发生关系？",
      "type": "问题",
      "evidence": "文本中列举的问题1",
      "segment_id": "颂皋_000_0fffa40d_s0000",
      "article_id": "颂皋_000_0fffa40d"
    },
    {
      "speaker": "颂皋",
      "content": "吾人所云'真理'，果作何解？",
      "type": "问题",
      "evidence": "文本中列举的问题2",
      "segment_id": "颂皋_000_0fffa40d_s0000",
      "article_id": "颂皋_000_0fffa40d"
    },
    {
      "speaker": "颂皋",
      "content": "一切事实均由材质而成，试问究竟有否此种普通之材质？",
      "type": "问题",
      "evidence": "文本中列举的问题3",
      "segment_id": "颂皋_000_0fffa40d_s0000",
      "article_id": "颂皋_000_0fffa40d"
    },
    {
      "speaker": "颂皋",
      "content": "世界究竟由何而来？往昔或竟不如是乎？",
      "type": "问题",
      "evidence": "文本中列举的问题4",
      "segment_id": "颂皋_000_0fffa40d_s0000",
      "article_id": "颂皋_000_0fffa40d"
    },
    {
      "speaker": "颂皋",
      "content": "何者为本体中之最真实者？",
      "type": "问题",
      "evidence": "文本中列举的问题5",
      "segment_id": "颂皋_000_0fffa40d_s0000",
      "article_id": "颂皋_000_0fffa40d"
    },
    {
      "speaker": "颂皋",
      "content": "凡百事物果如何而并合成一字宙？",
      "type": "问题",
      "evidence": "文本中列举的问题6",
      "segment_id": "颂皋_000_0fffa40d_s0000",
      "article_id": "颂皋_000_0fffa40d"
    },
    {
      "speaker": "康德",
      "content": "玄学上之重要问题有三：何为我所能知者？何为我所应为者？何为我可期望者？",
      "type": "主张",
      "evidence": "康德尝谓玄学上之重要问题有三",
      "segment_id": "颂皋_000_0fffa40d_s0002",
      "article_id": "颂皋_000_0fffa40d"
    },
    {
      "speaker": "桓儿夫",
      "content": "凡论及事物之可能者，是谓玄学，与备及事物之实在者，显非相同",
      "type": "定义",
      "evidence": "诚如桓儿夫（C. Wolff）所言",
      "segment_id": "颂皋_000_0fffa40d_s0002",
      "article_id": "颂皋_000_0fffa40d"
    },
    {
      "speaker": "作者",
      "content": "玄学乃所以探究一切事物之原因、本质、意义，及其结果者",
      "type": "定义",
      "evidence": "或曰：玄学者乃所以探究一切事物之原因、本质、意义，及其结果者",
      "segment_id": "颂皋_000_0fffa40d_s0002",
      "article_id": "颂皋_000_0fffa40d"
    },
    {
      "speaker": "作者",
      "content": "玄学实为研究本体之最普遍之原理之学",
      "type": "定义",
      "evidence": "或曰：玄学实为研究本体之最普遍之原理之学",
      "segment_id": "颂皋_000_0fffa40d_s0002",
      "article_id": "颂皋_000_0fffa40d"
    },
    {
      "speaker": "作者",
      "content": "原理之意义复杂，由原理完成之科学难有实现之望，此种定义直等于一装饰品",
      "type": "评价",
      "evidence": "原理之意义，既如是之复杂，由原理而完成之科学，又难有实现之望，然则此种定义，推其究竟，直等于一装饰品耳",
      "segment_id": "颂皋_000_0fffa40d_s0002",
      "article_id": "颂皋_000_0fffa40d"
    },
    {
      "speaker": "作者",
      "content": "玄学之最严重的职务在于研究单纯问题",
      "type": "主张",
      "evidence": "夫玄学之最严重的职务，不在乎他，即在乎研究此种单纯问题",
      "segment_id": "颂皋_000_0fffa40d_s0002",
      "article_id": "颂皋_000_0fffa40d"
    },
    {
      "speaker": "斯宾塞尔",
      "content": "世界非永久者，即为自我创造者；非自我创造者，则为外力所创造者",
      "type": "主张",
      "evidence": "文本中斯宾塞尔的观点",
      "segment_id": "颂皋_000_0fffa40d_s0003",
      "article_id": "颂皋_000_0fffa40d"
    },
    {
      "speaker": "作者",
      "content": "玄学之最严重的职务在于研究单纯问题",
      "type": "主张",
