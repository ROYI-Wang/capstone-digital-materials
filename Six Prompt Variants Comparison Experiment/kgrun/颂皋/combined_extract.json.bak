    },
    {
      "id": "颂皋_000_0fffa40d_s0002:c2",
      "speaker": "康德",
      "claim": "玄学上之重要问题有三，即：(1) 何为我所能知者?(2) 何为我所应为者?(3) 何为我可期望者?",
      "target": "玄学上之问题",
      "claim_type": "定义性主张",
