  "claims": [
    {
      "id": "颂皋_000_0fffa40d_s0000:c1",
      "speaker": "颂皋",
      "claim": "近来了在君先生与张君劢先生为科学与玄学之争，发表许多文章，引起学术界之注意。",
      "target": "科学与玄学之争",
